df_alloc = df_alloc,
intercept=-20,
coef_arm = -1  , # want lower prob for arm B
coef_age = - 0.025, # probability reduces with age
coef_sex = 0,
coef_stress= c(-0.3, 0.1, 0.5), # higher prob for high stress
coef_STEE = 4, ## strong baseline effect
coef_hidcat=-1,
coef_hidnorm=-1,
sd_err=2#,
#seed = 24601
){
#  set.seed(seed)
## First add the three latent variables
n_total = nrow(df_alloc)
hidden_norm = rnorm(n=n_total, mean=0, sd=1)
hidden_cat = sample(c("A", "B"), size=n_total, replace=T)
df_alloc$hid_norm = hidden_norm
df_alloc$hid_cat = as.factor(hidden_cat)
# This function needs to be changed
fx_temp = intercept +
coef_arm * (df_alloc$arm == "B") +
coef_age * df_alloc$Age +
coef_sex * (df_alloc$Sex == "F") +
coef_stress[1]*(df_alloc$StressScore=="low") +
coef_stress[2]*(df_alloc$StressScore=="moderate") +
coef_stress[3]*(df_alloc$StressScore=="high") +
coef_STEE * df_alloc$baseline_STEE +
coef_hidcat*as.numeric(df_alloc$hid_cat) +
coef_hidnorm*df_alloc$hid_norm +
rnorm(n_total, mean=0, sd=sd_err)
pi_vec = 1 / (1 + exp(-fx_temp))
df_alloc$fx = round(fx_temp, digits = 2)
df_alloc$pi = round(pi_vec, digits = 2)
out_temp = sapply(
1:n_total,
function(i){
sample(c(0,1), size=1, prob = c(1-pi_vec[i], pi_vec[i]))
}
)
df_alloc$outcome = out_temp
df_alloc
}
rt = run_trial(df_alloc = df_part)
rt
ggplot(rt, aes(x=baseline_STEE, y=pi)) + geom_point()
library(ggplot2)
ggplot(rt, aes(x=baseline_STEE, y=pi)) + geom_point()
ggplot(rt, aes(x=baseline_STEE, y=pi, col = StressScore)) + geom_point()
ggplot(rt, aes(x=age, y=pi, col = StressScore)) + geom_point()
ggplot(rt, aes(x=age, y=pi, col = arm)) + geom_point()
