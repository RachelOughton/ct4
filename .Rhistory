df_alloc$age_from25 = abs(df_alloc$age - 25)
# This function needs to be changed
fx_temp = intercept +
coef_arm * (df_alloc$arm == "B") +
coef_age25 * df_alloc$age_from25 +
coef_sex * (df_alloc$Sex == "F") +
coef_stress[1]*(df_alloc$StressScore=="low") +
coef_stress[2]*(df_alloc$StressScore=="moderate") +
coef_stress[3]*(df_alloc$StressScore=="high") +
coef_STEE * df_alloc$baseline_STEE +
coef_hidcat*as.numeric(df_alloc$hid_cat) +
coef_hidnorm*df_alloc$hid_norm +
rnorm(n_total, mean=0, sd=sd_err)
pi_vec = 1 / (1 + exp(-fx_temp))
df_alloc$fx = round(fx_temp, digits = 2)
df_alloc$pi = round(pi_vec, digits = 2)
out_temp = sapply(
1:n_total,
function(i){
sample(c(0,1), size=1, prob = c(1-pi_vec[i], pi_vec[i]))
}
)
df_alloc$outcome = out_temp
df_alloc
}
