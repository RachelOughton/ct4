ID = 1:n_total
age_raw = rnorm(n=2*n_total, mean = 24, sd = 6)
age_16plus = age_raw[age_raw >= 16]
age = age_16plus[1:n_total]
sex = sample(c("M", "F"), size = n_total, replace = T)
p_high = -0.1 + (1/80)*age
p_mod = rep(0.3, n_total)
p_low = 1 - (p_high+p_mod)
stress_score = sapply(
1:n_total,
function(i){
sample(c("low", "moderate", "high"), size = 1, prob = c(p_low[i], p_mod[i], p_high[i]))
}
)
## basline STEE frequency. Poisson(4.4 ish) censored?
## lambda should depend a bit on stress score
lam_df = data.frame(
stress = c("low", "moderate", "high"),
lam = c(3, 4, 6)
)
STEE = sapply(
1:n_total,
function(i){
lam_i = lam_df$lam[lam_df$stress == stress_score[i]]
rvec = rpois(n=20, lambda=lam_i)
rvec[rvec>=3][1]
}
)
df_part =  data.frame(
ID = ID,
Age = age,
Sex = sex,
StressScore = stress_score,
baseline_STEE = STEE
)
df_part$arm = sample(c("A", "B"), size= nrow(df_part), replace=T)
rt = run_trial(df_alloc = df_part)
rt
run_trial = function(
df_alloc = df_alloc,
intercept=-20,
coef_arm = -1  , # want lower prob for arm B
coef_age = - 0.025, # probability reduces with age
coef_sex = 0,
coef_stress= c(-0.3, 0.1, 0.5), # higher prob for high stress
coef_STEE = 4, ## strong baseline effect
coef_hidcat=-1,
coef_hidnorm=-1,
sd_err=2#,
#seed = 24601
){
#  set.seed(seed)
## First add the three latent variables
n_total = nrow(df_alloc)
hidden_norm = rnorm(n=n_total, mean=0, sd=1)
hidden_cat = sample(c("A", "B"), size=n_total, replace=T)
df_alloc$hid_norm = hidden_norm
df_alloc$hid_cat = as.factor(hidden_cat)
# This function needs to be changed
fx_temp = intercept +
coef_arm * (df_alloc$arm == "B") +
coef_age * df_alloc$Age +
coef_sex * (df_alloc$Sex == "F") +
coef_stress[1]*(df_alloc$StressScore=="low") +
coef_stress[2]*(df_alloc$StressScore=="moderate") +
coef_stress[3]*(df_alloc$StressScore=="high") +
coef_STEE * df_alloc$baseline_STEE +
coef_hidcat*as.numeric(df_alloc$hid_cat) +
coef_hidnorm*df_alloc$hid_norm +
rnorm(n_total, mean=0, sd=sd_err)
pi_vec = 1 / (1 + exp(-fx_temp))
df_alloc$fx = fx_temp
df_alloc$pi = pi_vec
out_temp = sapply(
1:n_total,
function(i){
sample(c(0,1), size=1, prob = c(1-pi_vec[i], pi_vec[i]))
}
)
df_alloc$outcome = out_temp
df_alloc
}
rt = run_trial(df_alloc = df_part)
rt
rt = run_trial(df_alloc = df_part)
rt
?round
round(rnorm(4, mean = 0, sd = 0.5), digits = 2)
